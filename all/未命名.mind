{"root":{"data":{"id":"d56dlom5tps0","created":1730010675548,"text":"第五章 通用输入/输出","background":"#73a1bf"},"children":[{"data":{"id":"d56dly17m740","created":1730010696049,"text":"5.1 GPIO概述"},"children":[{"data":{"id":"d56dr0cns480","created":1730011092916,"text":"端口号:通常以大写字母命名"},"children":[]},{"data":{"id":"d56dr7r26sg0","created":1730011109024,"text":"引脚号(以STM32F103ZET6为例)","layout_right_offset":{"x":21.249999050050974,"y":-32.499998547136784}},"children":[{"data":{"id":"d56dsx1asvs0","created":1730011242427,"text":"1.7组IO口"},"children":[]},{"data":{"id":"d56dt2fbg7k0","created":1730011254159,"text":"2.每组IO口有16个IO"},"children":[]},{"data":{"id":"d56dtamj9mw0","created":1730011272009,"text":"3.共有112个IO口"},"children":[]}]},{"data":{"id":"d56dshrua5s0","created":1730011209203,"text":"GPIO内部寄存器分类","layout_right_offset":{"x":-11.249999497085582,"y":272.49998781830095}},"children":[{"data":{"id":"d56dssn2y4w0","created":1730011232860,"text":"1.配置寄存器"},"children":[]},{"data":{"id":"d56dtfr693s0","created":1730011283174,"text":"2.数据寄存器"},"children":[]},{"data":{"id":"d56dtnb2vhc0","created":1730011299615,"text":"3.置位寄存器"},"children":[]},{"data":{"id":"d56duw6ai540","created":1730011397280,"text":"4.复位寄存器"},"children":[]},{"data":{"id":"d56duzhxcds0","created":1730011404514,"text":"5.锁定寄存器"},"children":[]}]},{"data":{"id":"d56dtuwq1p40","created":1730011316161,"text":"引脚分类","layout_right_offset":{"x":84.99999620020458,"y":-292.49998692423156}},"children":[{"data":{"id":"d56du25esn40","created":1730011331924,"text":"1.电源引脚"},"children":[]},{"data":{"id":"d56du3ffww00","created":1730011334707,"text":"2.晶振引脚"},"children":[]},{"data":{"id":"d56du8w0vmw0","created":1730011346594,"text":"3.复位引脚"},"children":[]},{"data":{"id":"d56duckdc080","created":1730011354596,"text":"4.BOOT引脚"},"children":[]},{"data":{"id":"d56dukesvgo0","created":1730011371674,"text":"5.程序下载引脚"},"children":[]},{"data":{"id":"d56dukz1vv40","created":1730011372898,"text":"6.GPIO引脚"},"children":[]}]}]},{"data":{"id":"d56dmisijk00","created":1730010741236,"text":"5.2 STM32的GPIO的工作模式与工作速度"},"children":[{"data":{"id":"d56dns7ksmg0","created":1730010840102,"text":"5.2.1 GPIO引脚","layout_right_offset":{"x":-1.2499999441206455,"y":-12.499999441206398}},"children":[]},{"data":{"id":"d56dnym0txk0","created":1730010854036,"text":"5.2.2 GPIO内部结构","layout_right_offset":{"x":-3.749999832362164,"y":0}},"children":[]},{"data":{"id":"d56docua8bs0","created":1730010885011,"text":"5.2.3 GPIO工作模式","layout_right_offset":{"x":0,"y":4.999999776482468}},"children":[{"data":{"id":"d56dxxj6b6o0","created":1730011635329,"text":"输出"},"children":[{"data":{"id":"d56dy630sew0","created":1730011653943,"text":"1.推挽输出模式（GPIO_MODE_OUT_PP）"},"children":[]},{"data":{"id":"d56dyq8wogo0","created":1730011697835,"text":"2.开漏输出模式（GPIO_MODE_OUT_OD）"},"children":[]},{"data":{"id":"d56dyz85ca80","created":1730011717380,"text":"3.复用推挽输出模式（GPIO_MODE_AF_PP）"},"children":[]},{"data":{"id":"d56dzcwrx5s0","created":1730011747167,"text":"4.复用开漏输出模式（GPIO_MODE_AF_OD）"},"children":[]}]},{"data":{"id":"d56dy1i4www0","created":1730011643973,"text":"输入"},"children":[{"data":{"id":"d56dyogn3fs0","created":1730011693949,"text":"1.上拉输入模式（GPIO_MODE_IPU)"},"children":[]},{"data":{"id":"d56dzr6iv880","created":1730011778231,"text":"2.下拉输入模式（GPIO_MODE_IPD）"},"children":[]},{"data":{"id":"d56e0nqmnig0","created":1730011849104,"text":"3.浮空输入模式（GPIO_MODE_IN_FLOATING）"},"children":[]},{"data":{"id":"d56e0wwpt3k0","created":1730011869063,"text":"4.模拟输入模式（GPIO_MODE_AIN）"},"children":[]}]}]},{"data":{"id":"d56doidr5ow0","created":1730010897072,"text":"5.2.4 GPIO输出速度"},"children":[{"data":{"id":"d56dw2jqkzc0","created":1730011489518,"text":"2MHZ"},"children":[]},{"data":{"id":"d56dw5naa800","created":1730011496263,"text":"10MHZ"},"children":[]},{"data":{"id":"d56dw7hehwg0","created":1730011500261,"text":"50MHZ"},"children":[]}]}]},{"data":{"id":"d56dolthck00","created":1730010904553,"text":"5.3 STM32时钟系统"},"children":[{"data":{"id":"d56doy8q0mo0","created":1730010931596,"text":"五个时钟源"},"children":[{"data":{"id":"d56e453e0m80","created":1730012121974,"text":"1.HSE——高速外部时钟 "},"children":[]},{"data":{"id":"d56ebnf0s1c0","created":1730012710408,"text":"2.HSI——高速内部时钟"},"children":[]},{"data":{"id":"d56e4khqcbk0","created":1730012155492,"text":"3.LSE——低速外部时钟"},"children":[]},{"data":{"id":"d56e4vgyvqw0","created":1730012179391,"text":"4.LSI——低速内部时钟"},"children":[]},{"data":{"id":"d56ebdydznc0","created":1730012689811,"text":"5.PLL——相位锁相环"},"children":[]}]},{"data":{"id":"d56dp5joh540","created":1730010947496,"text":"外设及系统时钟"},"children":[{"data":{"id":"d56ed64ywdk0","created":1730012829523,"text":"1.MCO——时钟输入"},"children":[]},{"data":{"id":"d56edex7b280","created":1730012848645,"text":"2.RTC——实时时钟"},"children":[{"data":{"id":"d56edm3a1w80","created":1730012864250,"text":"LSI"},"children":[]},{"data":{"id":"d56edq9r4680","created":1730012873348,"text":"LSE"},"children":[]},{"data":{"id":"d56edu77obk0","created":1730012881902,"text":"HSE 128分频"},"children":[]}]},{"data":{"id":"d56edkj9wl40","created":1730012860863,"text":"3.USBCLK——PLL时钟源"},"children":[{"data":{"id":"d56ef44mps80","created":1730012981878,"text":"48MHZ"},"children":[]},{"data":{"id":"d56ef5sz7q80","created":1730012985527,"text":"72MHZ"},"children":[]}]},{"data":{"id":"d56ef913upc0","created":1730012992548,"text":"4.SYSCLKM——系统时钟"},"children":[{"data":{"id":"d56eflbpd7s0","created":1730013019311,"text":"PLL"},"children":[]},{"data":{"id":"d56efnxdyqo0","created":1730013024975,"text":"HSI"},"children":[]},{"data":{"id":"d56efpwlvdk0","created":1730013029282,"text":"HSE"},"children":[]}]}]},{"data":{"id":"d56dpvv4wx40","created":1730011004785,"text":"五个重要时钟","layout_right_offset":{"x":7.499999664724328,"y":38.749998267740125}},"children":[{"data":{"id":"d56eg50lmqo0","created":1730013062175,"text":"1.SYSCLK——系统时钟"},"children":[]},{"data":{"id":"d56eghhqpn40","created":1730013089333,"text":"2.AHB——AHB"},"children":[{"data":{"id":"d56egpr6wm80","created":1730013107318,"text":"HCLK（72MHZ）"},"children":[]},{"data":{"id":"d56egthj4l40","created":1730013115441,"text":"APB1"},"children":[]},{"data":{"id":"d56egvmlmgw0","created":1730013120101,"text":"APB2"},"children":[]}]},{"data":{"id":"d56eh2u5nd40","created":1730013135796,"text":"1.APB1总线时钟（低速）"},"children":[]},{"data":{"id":"d56eha6ybrs0","created":1730013151807,"text":"2.APB2总线时钟（高速）"},"children":[]},{"data":{"id":"d56ehdz9ucw0","created":1730013160050,"text":"5.PLL时钟"},"children":[]}]}]},{"data":{"id":"d56dq7fgvd40","created":1730011029959,"text":"5.4 端口复用功能","layout_right_offset":{"x":-68.74999692663562,"y":106.24999525025532}},"children":[{"data":{"id":"d56ele21peg0","created":1730013473674,"text":"端口复用功能"},"children":[{"data":{"id":"d56elkv8lk00","created":1730013488500,"text":"概念:STM32有很多的内置外设（例如串口、ADC、DAC等等与内核在一起），这些外设的外部引脚都是与GPIO复用的"},"children":[]},{"data":{"id":"d56eqrwuefs0","created":1730013895655,"text":"复用端口初始化步骤"},"children":[{"data":{"id":"d56er0ruti80","created":1730013914945,"text":"1.GPIO端口时钟使能 RCC_APB2PERIPHCLOCKCMD(RCC_APB2PERIPH_GPIOA,ENABLE)"},"children":[]},{"data":{"id":"d56ern4p4c80","created":1730013963610,"text":"2.复用外设时钟使能 RCC_APB2PERIPHCLOCKCMD(RCC_APB2PERIPH_USART1,ENABLE)"},"children":[]},{"data":{"id":"d56es8kdtkw0","created":1730014010271,"text":"3.端口模式配置 GPIO_INIT()"},"children":[]}]}]},{"data":{"id":"d56elq6lpcw0","created":1730013500071,"text":"位操作定义"},"children":[]}]},{"data":{"id":"d56en47g8a80","created":1730013608961,"text":"项目实践","layout_right_offset":{"x":-173.99999655286445,"y":443.7499782256798}},"children":[{"data":{"id":"d56enlb43g80","created":1730013646188,"text":"IO口输出控制LED灯"},"children":[{"data":{"id":"d56f7i5mn5k0","created":1730015206610,"text":"基于位操作","layout_right_offset":{"x":39.99999821186066,"y":792.4999645724902}},"children":[{"data":{"id":"d56enzt02e00","created":1730013677745,"text":"步骤","layout_right_offset":{"x":19.99999910593033,"y":168.7499924562876}},"children":[{"data":{"id":"d56eo446g1k0","created":1730013687128,"text":"1.准备设备并搭建环境"},"children":[]},{"data":{"id":"d56eod2uxaw0","created":1730013706639,"text":"2.使能IO口时钟，配置寄存器RCC_APB2ENR"},"children":[]},{"data":{"id":"d56eorg204w0","created":1730013737912,"text":"3.初始化IO口模式。配置寄存器GPIOX_CRH/CRL"},"children":[]},{"data":{"id":"d56ep4au0og0","created":1730013765894,"text":"4.操作IO口，输出高低电平，配置寄存器GPIOX_ODR或BSRR/BBR"},"children":[]},{"data":{"id":"d56epjv5z8g0","created":1730013799775,"text":"5.调试代码到无报错后生成hex文件烧写进STM32开发板中"},"children":[]}]},{"data":{"id":"d56f8adixlc0","created":1730015268037,"text":"位操作基本原理：寄存器的某一位映射一个地址，向地址写1或0，就能向寄存器某一位写1或0","layout_right_offset":{"x":12.499999441206683,"y":-147.49999340623617}},"children":[]}]},{"data":{"id":"d56f8g0zxzc0","created":1730015280340,"text":"基于寄存器","layout_right_offset":{"x":264.9999881535767,"y":-3.7499998323619366}},"children":[{"data":{"id":"d56f8swm7xs0","created":1730015308373,"text":"每组IO口（PA-PG）含下面7个寄存器。这7个寄存器，可以控制一组GPIO的16个IO口（如PA组，16个IO口PA.0-PA.15）","layout_right_offset":{"x":254.99998860061203,"y":174.99999217689037}},"children":[{"data":{"id":"d56f8wunjvk0","created":1730015316962,"text":"GPIOx_CRL——端口配置低寄存器"},"children":[]},{"data":{"id":"d56f93w9m540","created":1730015332297,"text":"GPIOx_CRH——端口配置高寄存器"},"children":[]},{"data":{"id":"d56f9d5v2sg0","created":1730015352468,"text":"GPIOx_IDR——端口输入寄存器"},"children":[]},{"data":{"id":"d56f9h6zhgg0","created":1730015361243,"text":"GPIOx_ODR——端口输出寄存器"},"children":[]},{"data":{"id":"d56f9ny70qg0","created":1730015375949,"text":"GPIOx_BSRR——端口位设置/清除寄存器"},"children":[]},{"data":{"id":"d56f9qovc800","created":1730015381916,"text":"GPIOx_BRR——端口位清除寄存器"},"children":[]},{"data":{"id":"d56f9wg4x9s0","created":1730015394448,"text":"GPIOx_LCKR——端口配置锁存寄存器（不常用）"},"children":[]}]},{"data":{"id":"d56fa6imets0","created":1730015416366,"text":"步骤"},"children":[{"data":{"id":"d56fac591kg0","created":1730015428618,"text":"1.准备设备并搭建环境"},"children":[]},{"data":{"id":"d56fae8k6680","created":1730015433172,"text":"2.使能IO口时钟。配置寄存器RCC_APB2ENR"},"children":[]},{"data":{"id":"d56fajt9j1s0","created":1730015445308,"text":"3.初始化IO口模式。配置寄存器GPIOx_CRH/CRL"},"children":[]},{"data":{"id":"d56fan9zb940","created":1730015452849,"text":"4.操作IO口，输出高低电平。配置寄存器GPIOX_ODR或者BSRR/BRR"},"children":[]},{"data":{"id":"d56fatdflv40","created":1730015466120,"text":"5.调试代码到无报错后生成hex文件烧写进STM32开发板中"},"children":[]}]}]},{"data":{"id":"d56fbqtzaz40","created":1730015538953,"text":"基于库函数","layout_right_offset":{"x":144.9999935179951,"y":-1253.7499546818456}},"children":[{"data":{"id":"d56fckvjrls0","created":1730015604351,"text":"GPIO相关库函数介绍","layout_right_offset":{"x":126.24999435618531,"y":-1.2499999441206455}},"children":[{"data":{"id":"d56fcp0jacg0","created":1730015613360,"text":"2.头文件：stm32f10x_gpio.h","layout_right_offset":{"x":1.2499999441206455,"y":48.74999782070495}},"children":[]},{"data":{"id":"d56fcuc4geg0","created":1730015624944,"text":"1.源文件：stm32f10x_gpio.c","layout_right_offset":{"x":-2.499999888241291,"y":-62.499997206032276}},"children":[]}]},{"data":{"id":"d56fdc4w6a80","created":1730015663689,"text":"注意事项：要对GPIO进行操作，文件夹FWLIB里面的三个文件不能少","layout_right_offset":{"x":168.7499924562875,"y":-21.24999905005029}},"children":[{"data":{"id":"d56fdfqbzbk0","created":1730015671516,"text":"misc.c"},"children":[]},{"data":{"id":"d56fdjxrugg0","created":1730015680673,"text":"stm32f10x_gpio.c"},"children":[]},{"data":{"id":"d56fdm5citc0","created":1730015685485,"text":"stm32f10x_rcc.c"},"children":[]}]},{"data":{"id":"d56fdvj5yio0","created":1730015705911,"text":"重要函数"},"children":[{"data":{"id":"d56fdzbe1yw0","created":1730015714148,"text":"1个初始化函数"},"children":[{"data":{"id":"d56fe1lwtb40","created":1730015719138,"text":"void GPIO_Init(GPIO_TypeDef* GPIOx, GPIO_InitTypeDef* GPIO_InitStruct); "},"children":[]}]},{"data":{"id":"d56ff594m7c0","created":1730015805436,"text":"2个读取输入电平函数"},"children":[{"data":{"id":"d56ff7g6dy00","created":1730015810216,"text":"uint8_t GPIO_ReadInputDataBit(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);"},"children":[]},{"data":{"id":"d56ffcado400","created":1730015820749,"text":"uint16_t GPIO_ReadInputData(GPIO_TypeDef* GPIOx);"},"children":[]}]},{"data":{"id":"d56ffjvntyw0","created":1730015837274,"text":"2个读取输出电平函数"},"children":[{"data":{"id":"d56ffkrrjxc0","created":1730015839215,"text":"uint8_t GPIO_ReadOutputDataBit(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);"},"children":[]},{"data":{"id":"d56ffplo1140","created":1730015849730,"text":"uint16_t GPIO_ReadOutputData(GPIO_TypeDef* GPIOx);"},"children":[]}]},{"data":{"id":"d56fg0x236w0","created":1730015874363,"text":"4个设置输出电平函数"},"children":[{"data":{"id":"d56fg59hgww0","created":1730015883822,"text":"void GPIO_SetBits(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);//用得比较多"},"children":[]},{"data":{"id":"d56fgc76cuo0","created":1730015898920,"text":"void GPIO_ResetBits(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin) ;//用得比较多"},"children":[]},{"data":{"id":"d56fgff02xs0","created":1730015905923,"text":"void GPIO_WriteBit(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin, BitAction BitVal);//用得较少"},"children":[]},{"data":{"id":"d56fgl7h3480","created":1730015918529,"text":"void GPIO_Write(GPIO_TypeDef* GPIOx, uint16_t PortVal );//用得较少"},"children":[]}]}]},{"data":{"id":"d56fhb0mbhc0","created":1730015974711,"text":"步骤","layout_right_offset":{"x":56.24999748542905,"y":-47.4999978765843}},"children":[{"data":{"id":"d56fhgk57xc0","created":1730015986775,"text":"1.准备设备并搭建环境"},"children":[]},{"data":{"id":"d56fhhguj800","created":1730015988753,"text":"2. 使能IO口时钟。调用函数RCC_APB2PeriphColckCmd();"},"children":[]},{"data":{"id":"d56fhjd7xrc0","created":1730015992887,"text":"3.初始化IO口模式。调用函数GPIO_Init();"},"children":[]},{"data":{"id":"d56fhpte39s0","created":1730016006925,"text":"4.main.c,操作IO口，输出高低电平。 GPIO_SetBits();    GPIO_ResetBits();"},"children":[]},{"data":{"id":"d56fhvsbd8g0","created":1730016019921,"text":"5.硬件连接、下载、看效果"},"children":[]}]}]}]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}